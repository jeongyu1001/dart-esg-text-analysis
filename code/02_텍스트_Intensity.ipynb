    "seed_df = pd.read_csv('data/seed_dictionary.csv')\n",
    "print(f'Seed: {len(seed_df)}개 | 컬럼: {list(seed_df.columns)}')\n",
    "\n",
    "TOPN      = 30\n",
    "THRESHOLD = 0.55\n",
    "\n",
    "rows = []\n",
    "for _, row in seed_df.iterrows():\n",
    "    dim = row['dimension']\n",
    "    kw  = row['seed_term']   # 'keyword' → 'seed_term'\n",
    "    try:\n",
    "        neighbors = model.wv.most_similar(kw, topn=TOPN)\n",
    "    except:\n",
    "        continue\n",
    "    for word, score in neighbors:\n",
    "        if score < THRESHOLD or word == kw:\n",
    "            continue\n",
    "        rows.append({\n",
    "            'dimension': dim, 'seed_word': kw,\n",
    "            'expanded': word, 'cosine_sim': round(score,4),\n",
    "            'in_corpus': word in corpus_vocab,\n",
    "            'freq_corpus': token_freq.get(word,0)\n",
    "        })\n",
    "\n",
    "exp_df = pd.DataFrame(rows)\n",
    "print(f'총 후보: {len(exp_df)}개')\n",
    "if len(exp_df):\n",
    "    print(exp_df.groupby('dimension').size())\n",
    "\n",
    "in_corpus = exp_df[exp_df['in_corpus']].sort_values(['dimension','cosine_sim'], ascending=[True,False])\n",
    "print(f'\\nCorpus 내 유효 후보: {len(in_corpus)}개')\n",
    "for dim in ['E','S','G']:\n",
    "    sub = in_corpus[in_corpus['dimension']==dim].head(12)\n",
    "    label = {'E':'환경','S':'사회','G':'지배구조'}[dim]\n",
    "    print(f'\\n=== {dim} ({label}) ===')\n",
    "    print(sub[['seed_word','expanded','cosine_sim','freq_corpus']].to_string(index=False))\n"
   ]
