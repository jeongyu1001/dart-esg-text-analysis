      "=== 사용자 사전 효과 검증 ===\n",
      "  ✅ [컴플라이언스] → ['컴플라이언스', '강화', '준법', '지원', '선임']\n",
      "  ✅ [재활용] → ['재활용', '원료', '사용', '비율', '확대']\n",
      "  ❌ [독립성] → ['사외', '이사', '독립', '확보', '노력']\n",
      "  ❌ [의결권] → ['주주', '의결', '행사', '전자', '투표', '도입']\n",
      "  ✅ [넷제로] → ['넷제로', '달성', '탄소', '중립', '전략', '수립']\n"
     ]
    }
   ],
   "source": [
    "# 사용자 사전: Kiwi가 파손하는 ESG 복합어 5개\n",
    "# 근거: 전체 corpus 368문서 문장 맥락 테스트에서 0% 포착 + 의미 손실 확인\n",
    "USER_DICT = [\n",
    "    ('컴플라이언스', 'NNG'),   # 컴+플라이+언스로 파손\n",
    "    ('재활용',      'NNG'),   # 재(접두)+활용 → 활용만 남아 의미 변질\n",
    "    ('독립성',      'NNG'),   # 독립+성(접미) → G핵심어 접미 탈락\n",
    "    ('의결권',      'NNG'),   # 의결+권(접미) → G핵심어 접미 탈락\n",
    "    ('넷제로',      'NNG'),   # 넷+제로 분리 → E핵심어\n",
    "]\n",
    "\n",
    "kiwi = Kiwi()\n",
    "for word, pos in USER_DICT:\n",
    "    kiwi.add_user_word(word, pos)\n",
    "\n",
    "# 사용자 사전 효과 검증\n",
    "test_cases = [\n",
    "    ('컴플라이언스', '컴플라이언스 강화를 위해 준법지원인을 선임하였습니다.'),\n",
    "    ('재활용',      '재활용 원료 사용 비율을 확대하겠습니다.'),\n",
    "    ('독립성',      '사외이사의 독립성을 확보하기 위해 노력합니다.'),\n",
    "    ('의결권',      '주주의 의결권 행사를 위해 전자투표제를 도입하였습니다.'),\n",
    "    ('넷제로',      '2050 넷제로 달성을 위한 탄소중립 전략을 수립합니다.'),\n",
    "]\n",
    "print('=== 사용자 사전 효과 검증 ===')\n",
    "for word, sent in test_cases:\n",
    "    nng = [t.form for t in kiwi.tokenize(sent) if t.tag == 'NNG' and len(t.form) > 1]\n",
    "    captured = '✅' if word in nng else '❌'\n",
    "    print(f'  {captured} [{word}] → {nng}')"
   ]
  },
