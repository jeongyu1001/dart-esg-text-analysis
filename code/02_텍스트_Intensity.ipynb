    "def tokenize(text):\n",
    "    tokens = kiwi.tokenize(str(text))\n",
    "    return ' '.join([\n",
    "        t.form for t in tokens\n",
    "        if t.tag == 'NNG'\n",
    "        and len(t.form) > 1\n",
    "        and t.form not in stopwords\n",
    "    ])\n",
    "\n",
    "print('형태소 분석 중...')\n",
    "t0 = time.time()\n",
    "df['tokenized'] = df['ESG_passage'].apply(tokenize)\n",
    "elapsed = time.time() - t0\n",
    "\n",
    "counts = df['tokenized'].apply(lambda x: len(x.split()))\n",
    "print(f'완료 ({elapsed:.0f}초)')\n",
    "print(f'기업-연도별 토큰 수: 평균 {counts.mean():.0f} / 최소 {counts.min()} / 최대 {counts.max()}')\n",
    "df[['stock_code','fiscal_year','tokenized']].head(3)"
   ]
