    "    ('원래+확장 Seed',    ['E_seed_norm_log','G_seed_norm_log','E_seed_exp_log','G_seed_exp_log','neg_TFPC2','TFPC1','neg_SEPC1','SEPC7','E_intensive']),\n",
    "]:\n",
    "    avail = [c for c in xcols if c in merged.columns]\n",
    "    X = sm.add_constant(pd.concat([merged[avail].fillna(0), yr_dum], axis=1))\n",
