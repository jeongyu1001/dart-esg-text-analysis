    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "BASE = \"data\"\n",
    "\n",
    "seed   = pd.read_csv(\"ESG_키워드index_v2.csv\")\n",
    "ind_df = pd.read_csv("data/company_industry_dart.csv")\n",
    "ind_df['stock_code'] = ind_df['stock_code'].astype(str).str.zfill(6)\n",
    "seed['stock_code']   = seed['stock_code'].astype(str).str.zfill(6)\n",
    "\n",
    "# 업종 정보 병합 (DART API 수집 — KSIC 코드 기반)\n",
    "seed = seed.merge(\n",
    "    ind_df[['stock_code','induty_code','induty_name','E_intensive']],\n",
    "    on='stock_code', how='left'\n",
    ")\n",
    "\n",
    "# ── 1. 차원별 비율 (G 편향 통제) ─────────────────────────────\n",
    "seed['E_ratio'] = seed['E_seed'] / seed['ESG_seed_index']\n",
    "seed['S_ratio'] = seed['S_seed'] / seed['ESG_seed_index']\n",
    "seed['G_ratio'] = seed['G_seed'] / seed['ESG_seed_index']\n",
    "\n",
    "# ── 2. Winsorization 95th (E 이상치 완화) ────────────────────\n",
    "for dim in ['E','S','G']:\n",
    "    cap = seed[f'{dim}_seed'].quantile(0.95)\n",
    "    seed[f'{dim}_seed_win'] = seed[f'{dim}_seed'].clip(upper=cap)\n",
    "\n",
    "# ── 3. 길이정규화 + 로그 조합 ────────────────────────────────\n",
    "for dim in ['E','S','G','ESG']:\n",
    "    seed[f'{dim}_seed_norm_log'] = np.log1p(seed[f'{dim}_seed_norm'])\n",
    "\n",
    "# ── 4. 업종 내 z-score (E-intensive 효과 통제) ───────────────\n",
    "for dim in ['E','S','G']:\n",
    "    col = f'{dim}_seed_norm'\n",
