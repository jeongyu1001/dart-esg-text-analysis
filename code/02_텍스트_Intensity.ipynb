    "df[\"E_seed\"] = df[\"ESG_passage\"].apply(lambda x: count_seeds(x, DIM_PATTERNS[\"E\"]))\n",
    "df[\"S_seed\"] = df[\"ESG_passage\"].apply(lambda x: count_seeds(x, DIM_PATTERNS[\"S\"]))\n",
    "df[\"G_seed\"] = df[\"ESG_passage\"].apply(lambda x: count_seeds(x, DIM_PATTERNS[\"G\"]))\n",
    "df[\"ESG_seed_index\"] = df[\"E_seed\"] + df[\"S_seed\"] + df[\"G_seed\"]\n",
    "df[\"text_length\"]    = df[\"ESG_passage\"].apply(lambda x: len(str(x)))\n",
    "\n",
    "# 정규화 (per 1,000자)\n",
    "df[\"ESG_seed_norm\"] = df[\"ESG_seed_index\"] / (df[\"text_length\"] / 1000)\n",
    "df[\"E_seed_norm\"]   = df[\"E_seed\"]   / (df[\"text_length\"] / 1000)\n",
    "df[\"S_seed_norm\"]   = df[\"S_seed\"]   / (df[\"text_length\"] / 1000)\n",
    "df[\"G_seed_norm\"]   = df[\"G_seed\"]   / (df[\"text_length\"] / 1000)\n",
    "\n",
    "# 로그 변환 (log1p)\n",
    "df[\"ESG_seed_log\"] = np.log1p(df[\"ESG_seed_index\"])\n",
    "df[\"E_seed_log\"]   = np.log1p(df[\"E_seed\"])\n",
    "df[\"S_seed_log\"]   = np.log1p(df[\"S_seed\"])\n",
    "df[\"G_seed_log\"]   = np.log1p(df[\"G_seed\"])\n",
