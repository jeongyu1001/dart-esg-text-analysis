    "# 확장 seed score vs 기존 seed score 회귀 비교\n",
    "integ = pd.read_csv('data/4차_ESG_integrated_dataset.csv')\n",
    "integ['stock_code'] = integ['stock_code'].astype(str).str.zfill(6)\n",
    "\n",
    "exp_score = pd.read_csv('data/expanded_seed_score.csv')\n",
    "exp_score['stock_code'] = exp_score['stock_code'].astype(str).str.zfill(6)\n",
    "\n",
    "merged = integ.merge(exp_score, on=['stock_code','fiscal_year'], how='left')\n",
    "yr_dum = pd.get_dummies(merged['fiscal_year'], prefix='yr', drop_first=True).astype(int)\n",
    "y = merged['esg_numeric'].fillna(merged['esg_numeric'].median())\n",
    "\n",
    "base_r2 = 0.301\n",
    "for label, xcols in [\n",
    "    ('원래 Seed',        ['E_seed_norm_log','S_seed_norm_log','G_seed_norm_log','neg_TFPC2','TFPC1','neg_SEPC1','SEPC7','E_intensive']),\n",
