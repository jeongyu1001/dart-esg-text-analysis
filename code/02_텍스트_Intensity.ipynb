    "tok_df = pd.read_csv('data/ESG_passages_tokenized.csv')\n",
    "sentences = [str(t).split() for t in tok_df['tokenized'].dropna()]\n",
    "\n",
    "all_tokens = [w for s in sentences for w in s]\n",
    "token_freq = Counter(all_tokens)\n",
    "corpus_vocab = set(w for w, c in token_freq.items() if c >= 3)\n",
    "\n",
    "print(f'문서: {len(sentences)}개, 총 토큰: {len(all_tokens):,}, corpus 어휘: {len(corpus_vocab)}개')\n",
    "\n",
    "# gensim FastText 학습\n",
    "print('FastText 학습 중...')\n",
    "model = FastText(\n",
    "    sentences,\n",
    "    vector_size=100,\n",
    "    window=5,\n",
    "    min_count=3,\n",
    "    epochs=30,\n",
    "    workers=4,\n",
    "    sg=1           # skip-gram\n",
    ")\n",
    "print(f'학습 완료. vocab: {len(model.wv)}개')\n",
    "\n",
    "# seed 단어 유사어 미리보기\n",
    "for w in ['탄소','이사회','안전','온실가스','독립성']:\n",
    "    try:\n",
    "        sim = model.wv.most_similar(w, topn=5)\n",
    "        print(f'  {w}: {[s[0] for s in sim]}')\n",
    "    except: pass"
