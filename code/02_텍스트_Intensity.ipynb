    "import re\n",
    "\n",
    "passage_df = pd.read_csv('data/ESG_passage_기업-연도_final.csv')\n",
    "passage_df['stock_code'] = passage_df['stock_code'].astype(str).str.zfill(6)\n",
    "\n",
    "# corpus 내 확장어 (cosine≥0.60) 만 사용\n",
    "quality = in_corpus[in_corpus['cosine_sim'] >= 0.60]\n",
    "\n",
    "# 기존 seed + 확장어 통합 패턴\n",
    "DIM_PAT_EXP = {}\n",
    "for dim in ['E','S','G']:\n",
    "    orig_seeds = []\n",
    "    for p in seed_df[seed_df['dimension']==dim]['pattern']:\n",
    "        orig_seeds.extend([t.strip() for t in str(p).split('|') if t.strip()])\n",
    "    extra = quality[quality['dimension']==dim]['expanded'].tolist()\n",
    "    all_words = list(dict.fromkeys(orig_seeds + extra))\n",
    "    DIM_PAT_EXP[dim] = re.compile('|'.join(re.escape(w) for w in all_words))\n",
    "    print(f'{dim}: 원래 {len(orig_seeds)}개 + 확장 {len(extra)}개 = 총 {len(all_words)}개')\n",
    "\n",
    "for dim in ['E','S','G']:\n",
    "    passage_df[f'{dim}_seed_exp'] = passage_df['ESG_passage'].apply(\n",
    "        lambda x: len(DIM_PAT_EXP[dim].findall(str(x))))\n",
    "    text_len = passage_df['ESG_passage'].str.len().clip(lower=1)\n",
    "    passage_df[f'{dim}_seed_exp_norm'] = passage_df[f'{dim}_seed_exp'] / (text_len / 1000)\n",
    "    passage_df[f'{dim}_seed_exp_log'] = np.log1p(passage_df[f'{dim}_seed_exp_norm'])\n",
    "\n",
    "print('\\n확장 seed score 기술통계:')\n",
    "print(passage_df[['E_seed_exp','S_seed_exp','G_seed_exp']].describe().round(2))\n",
    "\n",
    "out_cols = ['stock_code','fiscal_year'] + [f'{d}_seed_exp' for d in 'ESG'] + \\\n",
    "           [f'{d}_seed_exp_norm' for d in 'ESG'] + [f'{d}_seed_exp_log' for d in 'ESG']\n",
    "passage_df[out_cols].to_csv('data/expanded_seed_score.csv', index=False, encoding='utf-8-sig')\n",
    "print(f'저장: expanded_seed_score.csv  {passage_df[out_cols].shape}')\n"
