    "import pandas as pd\n",
    "\n",
    "# ⑤ θ Sweep — FastText threshold 선택 근거\n",
    "# fasttext_expanded.csv: dimension, seed_word, expanded, cosine_sim, in_corpus, freq_corpus\n",
    "exp = pd.read_csv('data/fasttext_expanded.csv', encoding='utf-8-sig')\n",
    "\n",
    "print(\"=== θ Sweep — FastText 확장 사전 threshold 선택 근거 ===\\n\")\n",
    "print(f\"{'θ':>6} | {'전체 확장어':>10} | {'corpus 유효':>11} | {'저빈도(freq<5) 비율':>20} | 잡음 단어 예시\")\n",
    "print(\"-\"*90)\n",
    "\n",
    "chosen = 0.80\n",
    "for theta in [0.60, 0.65, 0.70, 0.75, 0.80, 0.85, 0.90]:\n",
    "    sub   = exp[exp['cosine_sim'] >= theta]\n",
    "    valid = sub[sub['in_corpus'] == True]\n",
    "    low_freq = valid[valid['freq_corpus'] < 5]\n",
    "    noise_ratio = len(low_freq) / len(valid) * 100 if len(valid) > 0 else 0\n",
    "    noise_sample = ', '.join(low_freq['expanded'].head(3).tolist()) if len(low_freq) > 0 else '-'\n",
    "    marker = ' ← 채택' if abs(theta - chosen) < 0.001 else ''\n",
    "    print(f\"  {theta:.2f} | {len(sub):>10} | {len(valid):>11} | {noise_ratio:>18.1f}% | {noise_sample}{marker}\")\n",
    "\n",
    "sub_c = exp[(exp['cosine_sim'] >= chosen) & (exp['in_corpus'] == True)]\n",
    "freq5 = sub_c[sub_c['freq_corpus'] >= 5]\n",
    "print()\n",
    "print(f\"채택 θ = {chosen}  (corpus 내 유효 확장어: {len(sub_c)}개, freq≥5: {len(freq5)}개)\")\n",
    "print()\n",
    "print(\"선택 근거:\")\n",
    "print(\"  - θ < 0.75: 저빈도·비ESG 단어(콩기름, 분기 등) 유입율 높아 잡음 증가\")\n",
    "print(\"  - θ > 0.85: 확장어 수 급감(4개 이하), 확장 효과 미미\")\n",
    "print(\"  - θ = 0.80: corpus 유효 단어 확보 + 잡음 최소화 균형점 (Bao et al. 2024 준용)\")"
   ]
